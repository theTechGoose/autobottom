// --- Logging ---

[REQ] flushLogs(FlushLogsDto): SuccessDto
    logger::formatBatch(FlushLogsDto): FormattedLogDto
    ex:loki::pushBatch(FormattedLogDto): void
      timeout network-error
    success::ok(): SuccessDto


[NON] auth
    authentication service handling user
    lookup and password verification
[NON] session
    stored auth state snapshot with ttl
[NON] team
    nestable organizational unit forming
    the scope hierarchy
[NON] role
    configurable role definition with
    capabilities and permissions
[NON] user
    stored user identity with cached role
    fields
[NON] auditConfig
    versioned audit template defining
    questions fields and skip rules
[NON] auditBatch
    batch container grouping multiple audit
    instances into a single submission
[NON] inst
    single audit execution against one
    recording tracking status and results
[NON] auditResult
    scoring pass appended to audit results
    array with origin llm reviewer or judge
[NON] pipeline
    queue-driven orchestrator for audit
    pipeline steps
[NON] recording
    external recording download service
[NON] transcription
    speech-to-text transcription service
[NON] llm
    large language model service for
    diarization and question answering
[NON] rag
    retrieval augmented generation service
    for document retrieval
[NON] skipRule
    conditional logic removing questions
    based on field values
[NON] question
    audit question with text expected answer
    type and rag params
[NON] review
    reviewer workflow managing claim-lock
    checklist for audit review
[NON] reviewChecklist
    transient per-audit checklist tracking
    per-question claim and decision state
[NON] appeal
    appeal workflow managing filing
    assignment and judge decision
[NON] appealRecord
    stored appeal entity linking audit
    finding agent and judge
[NON] appealChecklist
    transient per-appeal checklist tracking
    per-question claim and decision state
[NON] coaching
    post-audit follow-up tracking pending
    and completed coaching per agent
[NON] gameCfg
    per-team gamification toggle threshold
    and combo timeout with cascade
[NON] player
    per-user gamification profile with xp
    tokens avatar inventory and badges
[NON] badge
    badge evaluation engine filtering
    criteria and checking thresholds
[NON] badgeDef
    stored badge definition with criteria
    threshold and xp reward
[NON] storeItem
    purchasable cosmetic item in the
    gamification store
[NON] evtCfg
    stored reactive automation triggered by
    events with conditions and delivery
[NON] comms
    polymorphic notification dispatcher
    selecting webhook email chat or sse
[NON] notifier
    notification delivery queue for rendered
    event payloads
[NON] message
    direct message between two users
[NON] report
    saved data view combining query type
    and display options
[NON] query
    report query engine for filter sort
    group and formula evaluation
[NON] dashboard
    dashboard persistence service
[NON] provider
    adapter turning code string into
    sandboxed execution with idempotency
[NON] provDef
    developer-defined provider with type
    name and config schema
[NON] provCfg
    admin-configured provider credentials
    per team with cascade delegation
[NON] binding
    per-team wiring of named services to
    ordered provider fallback chains
[NON] circuit
    health tracker marking degraded
    providers and skipping them in chain
[NON] idempoter
    reliability kernel for effectively-once
    execution via lease-based locking
[NON] reconciler
    callback confirming whether a side
    effect actually happened
[NON] qlQuestion
    question lab question under development
    with version history
[NON] qlTest
    question lab test case with snippet
    expected answer and last result
[NON] qTest
    test comparator checking llm answer
    against expected result
[NON] logger
    structured log formatter for loki
    ingestion
[NON] loki
    grafana cloud loki push api for log
    storage
[NON] success
    simple success result builder
[NON] qlConfig
    question lab configuration grouping
    questions under development
[NON] avatar
    embedded player visual identity with
    letter flair and equipped slot ids
[NON] inventory
    flat list of all purchased store item
    ids owned by the player
[NON] eventBinding
    player-chosen celebration gif for a
    specific event type
[NON] badgeProgress
    tracking counter toward earning a
    specific badge definition
[NON] earnedBadge
    completed badge record with timestamp
    on player profile
[NON] effect
    visual effect primitive with sandboxed
    css and js knob functions
[NON] appliedEffect
    effect instance with knob values
    filled in for a store item or combo
[NON] themeDef
    full app color scheme with twelve hex
    values purchasable from the store
[NON] comboPack
    combo effect bundle with tiered
    consumers for queue processing
[NON] comboConsumer
    independent effect pipeline running on
    floating letter elements during combos
[NON] comboTier
    single tier pairing an applied effect
    with optional sound
[NON] filterGroup
    recursive and-or filter structure
    reused by reports and event configs
[NON] filterCondition
    single filter predicate with field
    key operator and value
[NON] sortCriterion
    sort column with ascending or
    descending order
[NON] groupCriterion
    grouping column with bucketing method
    for report aggregation
[NON] formulaField
    user-defined computed column evaluated
    per row at query time
[NON] reportFolder
    organizational container for saved
    reports with default flag
[NON] reportOptions
    shared display settings for all report
    types including row height and color
[NON] reportProperties
    type-specific visualization config
    varying by report type
[NON] widgetSlot
    positioned widget in a dashboard grid
    with column order and span
[NON] widgetType
    widget kind enum selecting the
    renderer and config shape
[NON] fieldDef
    input field schema defining required
    data per audit instance
[NON] ragParams
    per-question rag retrieval settings
    controlling vector search behavior
[NON] questionType
    answer validation type with regex
    parser and json schema
[NON] pipelineConfig
    operational tuning for retry limit
    and delay between pipeline retries
[NON] appEvent
    ephemeral per-user event with 24h ttl
    delivered via sse stream
[NON] broadcastEvent
    org-wide announcement event with 24h
    ttl displayed on gamification feed
[NON] prefabEventDef
    pre-defined broadcast event type with
    default message template
[NON] mktItem
    marketplace item published by
    developers and installed per org
[NON] idempotencyRecord
    lease-based execution record tracking
    state attempts and expiry
[NON] sidebar
    computed navigation surface derived
    from session capabilities at login
[NON] leaderboard
    computed ranking of users by review
    speed decisions or flip rate


[TYP] email: string
