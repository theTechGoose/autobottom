// ============================================
// Auto-Bot V2 -- audit automation platform
// ============================================


// --- Auth ---

[REQ] login(LoginDto): SessionDto
    auth::lookupUser(email): UserRecordDto
      not-found
    auth::verifyPassword(password, passwordHash): void
      invalid-credentials
    session::build(UserRecordDto): SessionDto
    db:session::save(SessionDto): SessionDto
      timeout
    [RET] SessionDto


[REQ] impersonate(ImpersonateDto): SessionDto
    auth::lookupUser(email): UserRecordDto
      not-found
    auth::checkImpersonate(ImpersonateDto, UserRecordDto): void
      forbidden
    session::buildImpersonated(ImpersonateDto, UserRecordDto): SessionDto
    db:session::save(SessionDto): SessionDto
      timeout
    [RET] SessionDto


// --- Team Management ---

[REQ] createTeam(CreateTeamDto): TeamDto
    team::validate(CreateTeamDto): void
      invalid
    db:team::create(CreateTeamDto): TeamDto
      timeout
    [RET] TeamDto


[REQ] updateTeam(UpdateTeamDto): TeamDto
    db:team::load(teamId): TeamDto
      not-found
    team::applyChanges(TeamDto, UpdateTeamDto): TeamDto
    db:team::update(TeamDto): TeamDto
      timeout
    [RET] TeamDto


[REQ] addTeamMember(AddMemberDto): TeamDto
    db:team::load(teamId): TeamDto
      not-found
    team::addMember(TeamDto, memberEmail): TeamDto
      already-exists
    db:team::update(TeamDto): TeamDto
      timeout
    [RET] TeamDto


[REQ] removeTeamMember(
    RemoveMemberDto): TeamDto
    db:team::load(teamId): TeamDto
      not-found
    team::removeMember(TeamDto, memberEmail): TeamDto
      not-found
    db:team::update(TeamDto): TeamDto
      timeout
    [RET] TeamDto


[REQ] changeTeamLeader(
    ChangeLeaderDto): TeamDto
    db:team::load(teamId): TeamDto
      not-found
    team::setLeader(TeamDto, leaderId): TeamDto
    db:team::update(TeamDto): TeamDto
      timeout
    [RET] TeamDto


// --- Role Management ---

[REQ] createRole(CreateRoleDto): RoleDefDto
    role::validate(CreateRoleDto): void
      invalid
    db:role::create(CreateRoleDto): RoleDefDto
      timeout
    [RET] RoleDefDto


[REQ] updateRole(UpdateRoleDto): RoleDefDto
    db:role::load(roleId): RoleDefDto
      not-found
    role::applyChanges(RoleDefDto, UpdateRoleDto): RoleDefDto
    db:role::update(RoleDefDto): RoleDefDto
      timeout
    db:user::fanOutRoleUpdate(RoleDefDto): void
      timeout
    [RET] RoleDefDto


// --- User Management ---

[REQ] createUser(CreateUserDto): UserRecordDto
    auth::hashPassword(password): passwordHash
    user::build(CreateUserDto, passwordHash): UserRecordDto
    db:user::save(UserRecordDto): UserRecordDto
      timeout
    [RET] UserRecordDto


[REQ] deactivateUser(
    DeactivateUserDto): UserRecordDto
    db:user::load(email): UserRecordDto
      not-found
    user::deactivate(UserRecordDto): UserRecordDto
    db:user::save(UserRecordDto): UserRecordDto
      timeout
    [RET] UserRecordDto


[REQ] changePassword(
    ChangePasswordDto): SuccessDto
    db:user::load(email): UserRecordDto
      not-found
    auth::verifyPassword(password, passwordHash): void
      invalid-credentials
    auth::hashNewPassword(newPassword): newHash
    user::setHash(UserRecordDto, newHash): UserRecordDto
    db:user::save(UserRecordDto): UserRecordDto
      timeout
    success::ok(): SuccessDto


// --- Audit Config ---

[REQ] createAuditConfig(
    CreateAuditConfigDto): AuditConfigDto
    auditConfig::build(CreateAuditConfigDto): AuditConfigDto
    db:auditConfig::save(AuditConfigDto): AuditConfigDto
      timeout
    [RET] AuditConfigDto


[REQ] updateAuditConfig(
    UpdateAuditConfigDto): AuditConfigDto
    db:auditConfig::load(configId): AuditConfigDto
      not-found
    auditConfig::apply(AuditConfigDto, UpdateAuditConfigDto): AuditConfigDto
    db:auditConfig::save(AuditConfigDto): AuditConfigDto
      timeout
    [RET] AuditConfigDto


// --- Audit Pipeline ---

[REQ] submitBatch(SubmitBatchDto): AuditBatchDto
    auditBatch::create(SubmitBatchDto): AuditBatchDto
    db:auditBatch::save(AuditBatchDto): AuditBatchDto
      timeout
    auditBatch::fanOut(AuditBatchDto): InstanceListDto
    db:inst::saveAll(InstanceListDto): InstanceListDto
      timeout
    mq:pipeline::enqueueAll(InstanceListDto): void
      timeout
    [RET] AuditBatchDto


[REQ] initAudit(InitAuditDto): InstDto
    db:inst::load(instanceId): InstDto
      not-found
    inst::markCreating(InstDto): InstDto
    db:inst::save(InstDto): InstDto
      timeout
    ex:recording::download(recordingUrl): recordingData
      not-found timeout
    mq:pipeline::enqueueTranscribe(instanceId): void
      timeout
    [RET] InstDto


[REQ] transcribeAudit(TranscribeDto): InstDto
    db:inst::load(instanceId): InstDto
      not-found
    inst::markTranscribing(InstDto): InstDto
    ex:transcription::transcribe(recordingData): RawTranscriptDto
      timeout
    ex:llm::diarize(RawTranscriptDto): TranscriptDto
      timeout
    inst::addTranscript(InstDto, TranscriptDto): InstDto
    db:inst::save(InstDto): InstDto
      timeout
    mq:pipeline::enqueuePrepare(instanceId): void
      timeout
    [RET] InstDto


[REQ] prepareQuestions(PrepareDto): PreparedDto
    db:inst::load(instanceId): InstDto
      not-found
    db:auditConfig::load(configId): AuditConfigDto
      not-found
    skipRule::evaluate(AuditConfigDto, fieldMap): SkipResultDto
    question::populate(AuditConfigDto, fieldMap): QuestionListDto
    question::filterSkipped(QuestionListDto, SkipResultDto): PreparedDto
    mq:pipeline::enqueueBatches(instanceId, PreparedDto): void
      timeout
    [RET] PreparedDto


[REQ] askQuestionBatch(
    AskBatchDto): AskBatchResultDto
    db:inst::load(instanceId): InstDto
      not-found
    ex:rag::retrieveForAudit(AskBatchDto, TranscriptDto): RagResultDto
      timeout
    ex:llm::askBatch(AskBatchDto, RagResultDto, TranscriptDto): AnswerListDto
      timeout
    question::evaluate(AnswerListDto, AskBatchDto): EvalListDto
    pipeline::decrementCounter(instanceId): remaining
    pipeline::checkComplete(remaining): fanInReady
    pipeline::buildResult(EvalListDto, remaining, fanInReady): AskBatchResultDto


[REQ] finalizeAudit(FinalizeDto): InstDto
    db:inst::load(instanceId): InstDto
      not-found
    auditResult::build(InstDto): AuditResultDto
    inst::appendResult(InstDto, AuditResultDto): InstDto
    ex:llm::generateFeedback(AuditResultDto, TranscriptDto): FeedbackDto
      timeout
    inst::setFeedback(InstDto, FeedbackDto): InstDto
    inst::resolve(InstDto): InstDto
    db:inst::save(InstDto): InstDto
      timeout
    [RET] InstDto


// --- Review ---

[REQ] createReviewChecklist(
    CreateChecklistDto): ReviewChecklistDto
    db:inst::load(instanceId): InstDto
      not-found
    review::buildChecklist(InstDto): ReviewChecklistDto
    db:reviewChecklist::save(ReviewChecklistDto): ReviewChecklistDto
      timeout
    [RET] ReviewChecklistDto


[REQ] claimReviewItem(
    ClaimReviewDto): ReviewItemDto
    db:reviewChecklist::load(instanceId): ReviewChecklistDto
      not-found
    review::claimNext(ReviewChecklistDto, reviewerEmail): ReviewItemDto
      none-available
    db:reviewChecklist::save(ReviewChecklistDto): ReviewChecklistDto
      timeout conflict
    [RET] ReviewItemDto


[REQ] submitReviewDecision(
    ReviewDecisionDto): ReviewChecklistDto
    db:reviewChecklist::load(instanceId): ReviewChecklistDto
      not-found
    review::decide(ReviewChecklistDto, ReviewDecisionDto): ReviewChecklistDto
    db:reviewChecklist::save(ReviewChecklistDto): ReviewChecklistDto
      timeout
    [RET] ReviewChecklistDto


[REQ] consolidateReview(
    ConsolidateReviewDto): InstDto
    db:reviewChecklist::load(instanceId): ReviewChecklistDto
      not-found
    review::consolidate(ReviewChecklistDto): AuditResultDto
    db:inst::load(instanceId): InstDto
      not-found
    inst::appendResult(InstDto, AuditResultDto): InstDto
    inst::resolve(InstDto): InstDto
    db:inst::save(InstDto): InstDto
      timeout
    db:reviewChecklist::archive(instanceId): void
      timeout
    [RET] InstDto


// --- Appeals ---

[REQ] fileAppeal(FileAppealDto): AppealRecordDto
    db:inst::load(instanceId): InstDto
      not-found
    appeal::validate(InstDto, findingId): void
      invalid already-appealed
    appeal::createRecord(FileAppealDto): AppealRecordDto
    db:appealRecord::save(AppealRecordDto): AppealRecordDto
      timeout
    inst::markAppealPending(InstDto): InstDto
    db:inst::save(InstDto): InstDto
      timeout
    appeal::buildChecklist(AppealRecordDto, InstDto): AppealChecklistDto
    db:appealChecklist::save(AppealChecklistDto): AppealChecklistDto
      timeout
    [RET] AppealRecordDto


[REQ] assignAppeal(
    AssignAppealDto): AppealRecordDto
    db:appealRecord::load(appealId): AppealRecordDto
      not-found
    appeal::assign(AppealRecordDto, judgeEmail): AppealRecordDto
    db:appealRecord::save(AppealRecordDto): AppealRecordDto
      timeout
    [RET] AppealRecordDto


[REQ] submitAppealDecision(
    AppealDecisionDto): AppealChecklistDto
    db:appealChecklist::load(appealId): AppealChecklistDto
      not-found
    appeal::decide(AppealChecklistDto, AppealDecisionDto): AppealChecklistDto
    db:appealChecklist::save(AppealChecklistDto): AppealChecklistDto
      timeout
    [RET] AppealChecklistDto


[REQ] consolidateAppeal(
    ConsolidateAppealDto): InstDto
    db:appealChecklist::load(appealId): AppealChecklistDto
      not-found
    appeal::consolidate(AppealChecklistDto): AuditResultDto
    db:inst::load(instanceId): InstDto
      not-found
    inst::appendResult(InstDto, AuditResultDto): InstDto
    inst::resolve(InstDto): InstDto
    db:inst::save(InstDto): InstDto
      timeout
    db:appealRecord::load(appealId): AppealRecordDto
      not-found
    appeal::resolveRecord(AppealRecordDto): AppealRecordDto
    db:appealRecord::save(AppealRecordDto): AppealRecordDto
      timeout
    db:appealChecklist::archive(appealId): void
      timeout
    [RET] InstDto


// --- Coaching ---

[REQ] queueCoaching(
    QueueCoachingDto): CoachingRecordDto
    db:coaching::load(agentEmail): CoachingRecordDto
      not-found
    coaching::addPending(CoachingRecordDto, instanceId): CoachingRecordDto
    db:coaching::save(CoachingRecordDto): CoachingRecordDto
      timeout
    [RET] CoachingRecordDto


[REQ] addressCoaching(
    AddressCoachingDto): CoachingRecordDto
    db:coaching::load(agentEmail): CoachingRecordDto
      not-found
    coaching::address(CoachingRecordDto, AddressCoachingDto): CoachingRecordDto
    db:coaching::save(CoachingRecordDto): CoachingRecordDto
