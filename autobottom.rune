    query::evalFormulas(ReportDto): FormulaResultListDto
    query::applyFilter(ReportDto, FormulaResultListDto): FilteredListDto
    query::applySort(FilteredListDto): SortedListDto
    query::applyGroup(SortedListDto): ReportResultDto


[REQ] createReportFolder(
    CreateFolderDto): ReportFolderDto
    reportFolder::build(CreateFolderDto): ReportFolderDto
    db:reportFolder::save(ReportFolderDto): ReportFolderDto
      timeout
