    [RET] CoachingRecordDto


// --- Gamification ---

[REQ] earnXp(EarnXpDto): PlayerDto
    db:gameCfg::resolve(teamId): GameCfgDto
      not-found
    gameCfg::checkThreshold(score, threshold): qualifies
    db:player::load(playerEmail): PlayerDto
      not-found
    player::awardXp(PlayerDto, amount): PlayerDto
    player::checkLevelUp(PlayerDto): leveledUp
    player::updateStreak(PlayerDto): PlayerDto
    db:player::save(PlayerDto): PlayerDto
      timeout
    [RET] PlayerDto


[REQ] purchaseItem(PurchaseItemDto): PlayerDto
    db:storeItem::load(itemId): StoreItemDto
      not-found
    db:player::load(playerEmail): PlayerDto
      not-found
    player::checkBalance(PlayerDto, price): void
      insufficient-balance
    player::checkOwnership(PlayerDto, itemId): void
      already-owned
    player::deductTokens(PlayerDto, price): PlayerDto
    player::addToInventory(PlayerDto, itemId): PlayerDto
    db:player::save(PlayerDto): PlayerDto
      timeout
    [RET] PlayerDto


[REQ] equipItem(EquipItemDto): PlayerDto
    db:player::load(playerEmail): PlayerDto
      not-found
    player::checkInventory(PlayerDto, itemId): void
      not-owned
    player::equip(PlayerDto, itemId, slot): PlayerDto
    db:player::save(PlayerDto): PlayerDto
      timeout
    [RET] PlayerDto


[REQ] evaluateBadge(
    EvaluateBadgeDto): PlayerDto
    db:badgeDef::loadActive(badgeRole): BadgeListDto
    db:player::load(playerEmail): PlayerDto
      not-found
    badge::filterCriteria(BadgeListDto, eventPayload): MatchListDto
    badge::computeIncrements(MatchListDto, eventPayload): IncrementListDto
    player::updateBadgeProgress(PlayerDto, IncrementListDto): PlayerDto
    player::checkBadgeThresholds(PlayerDto): EarnedListDto
    player::awardBadgeXp(PlayerDto, EarnedListDto): PlayerDto
    db:player::save(PlayerDto): PlayerDto
      timeout
    [RET] PlayerDto


[REQ] purchaseTheme(
    PurchaseThemeDto): PlayerDto
    db:themeDef::load(themeId): ThemeDefDto
      not-found
    db:player::load(playerEmail): PlayerDto
      not-found
    player::checkBalance(PlayerDto, price): void
      insufficient-balance
    player::deductTokens(PlayerDto, price): PlayerDto
    player::addThemeToInventory(PlayerDto, themeId): PlayerDto
    db:player::save(PlayerDto): PlayerDto
      timeout
    [RET] PlayerDto


[REQ] equipTheme(EquipThemeDto): PlayerDto
    db:player::load(playerEmail): PlayerDto
      not-found
    player::checkThemeOwned(PlayerDto, themeId): void
      not-owned
    player::setTheme(PlayerDto, themeId): PlayerDto
    db:player::save(PlayerDto): PlayerDto
      timeout
    [RET] PlayerDto


[REQ] purchaseComboPack(
    PurchaseComboDto): PlayerDto
    db:comboPack::load(comboPackId): ComboPackDto
      not-found
    db:player::load(playerEmail): PlayerDto
      not-found
    player::checkBalance(PlayerDto, price): void
      insufficient-balance
    player::deductTokens(PlayerDto, price): PlayerDto
    player::addComboToInventory(PlayerDto, comboPackId): PlayerDto
    db:player::save(PlayerDto): PlayerDto
      timeout
    [RET] PlayerDto


[REQ] equipComboPack(
    EquipComboDto): PlayerDto
    db:player::load(playerEmail): PlayerDto
      not-found
    player::checkComboOwned(PlayerDto, comboPackId): void
      not-owned
    player::setComboPack(PlayerDto, comboPackId): PlayerDto
    db:player::save(PlayerDto): PlayerDto
      timeout
    [RET] PlayerDto


[REQ] updateGameSettings(
    UpdateGameCfgDto): GameCfgDto
    db:gameCfg::load(teamId): GameCfgDto
      not-found
    gameCfg::apply(GameCfgDto, UpdateGameCfgDto): GameCfgDto
    db:gameCfg::save(GameCfgDto): GameCfgDto
      timeout
    [RET] GameCfgDto


// --- Events ---

[REQ] emitEvent(EmitEventDto): EmitResultDto
    db:evtCfg::matchTrigger(eventType): CfgListDto
    evtCfg::filterFields(CfgListDto, eventPayload): CfgListDto
    evtCfg::evalConditions(CfgListDto, eventPayload): CfgListDto
    evtCfg::renderPayloads(CfgListDto, eventPayload): PayloadListDto
    mq:notifier::enqueueAll(PayloadListDto): void
      timeout
    evtCfg::buildResult(PayloadListDto): EmitResultDto


[REQ] deliverNotification(
    DeliverNotificationDto): SuccessDto
    comms::resolve(communicationType): comms
    [PLY] comms.deliver(RenderedPayloadDto): void
        [CSE] webhook
        ex:comms.sendWebhook(RenderedPayloadDto): void
          timeout network-error
        [CSE] email
        ex:comms.sendEmail(RenderedPayloadDto): void
          timeout network-error
        [CSE] chat
        ex:comms.sendChat(RenderedPayloadDto): void
          timeout network-error
        [CSE] sse
        ex:comms.sendSse(RenderedPayloadDto): void
          timeout
    success::ok(): SuccessDto


[REQ] createEventConfig(
    CreateEvtCfgDto): EventConfigDto
    evtCfg::build(CreateEvtCfgDto): EventConfigDto
    db:evtCfg::save(EventConfigDto): EventConfigDto
      timeout
    [RET] EventConfigDto


