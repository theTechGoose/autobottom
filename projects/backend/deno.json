{
  "name": "@autobottom/backend",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "tasks": {
    "dev": "deno run --allow-all --watch src/bootstrap.ts",
    "test": "deno test --allow-all --no-check --unstable-kv",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "check": "deno check src/bootstrap.ts"
  },
  "imports": {
    "nanoid": "npm:nanoid@^5.0.0",
    "groq-sdk": "npm:groq-sdk",
    "openai": "npm:openai",
    "zod": "npm:zod",
    "@std/assert": "jsr:@std/assert@^1",
    "@std/testing": "jsr:@std/testing@^1"
  },
  "exclude": [
    "node_modules/",
    "sounds/"
  ]
}
