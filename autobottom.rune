// --- Provider Resolution ---

[REQ] resolveProvider(
    ResolveProviderDto): ProviderConfigDto
    db:team::loadAncestors(teamId): AncestorListDto
    provider::walkTree(AncestorListDto, providerType): ProviderConfigDto
      not-found
    [RET] ProviderConfigDto


[REQ] resolveBinding(
    ResolveBindingDto): ServiceBindingDto
    db:team::loadAncestors(teamId): AncestorListDto
    binding::walkTree(AncestorListDto, serviceName): ServiceBindingDto
      not-found
    [RET] ServiceBindingDto


[REQ] executeWithFallback(
    ExecuteFallbackDto): ExecutionResultDto
    db:binding::load(bindingId): ServiceBindingDto
    binding::getChain(ServiceBindingDto): ChainListDto
    circuit::filterHealthy(ChainListDto): ChainListDto
      all-degraded
    provider::tryChain(ChainListDto, execPayload): ExecutionResultDto
      all-failed
    [RET] ExecutionResultDto


[REQ] providerSend(
    ProviderSendDto): CodeReturnDto
    provider::hashKey(code, execPayload): idempotencyKey
    idempoter::execute(idempotencyKey, code, execPayload): CodeReturnDto
      sandbox-error
    [RET] CodeReturnDto


[REQ] providerGuaranteeSend(
    GuaranteeSendDto): GuaranteeResultDto
    provider::hashKey(code, execPayload): idempotencyKey
    idempoter::execute(idempotencyKey, code, execPayload): CodeReturnDto
      sandbox-error
    ex:reconciler::reconcile(idempotencyKey): ReceiptDto
      timeout not-confirmed
    idempoter::mark(idempotencyKey, ReceiptDto): void
    provider::buildGuarantee(ReceiptDto, CodeReturnDto): GuaranteeResultDto


